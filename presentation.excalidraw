      "seed": 797231372,
      "version": 340,
      "versionNonce": 735293964,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774359797236,
      "link": null,
      "locked": false,
      "text": "Collector\n    * initiliaziation : \n        Ex: collection vide, chaîne vide, somme 0 (Supplier)\n    * accumulator : traitemenent des données 1 par 1\n        Ex: Collection.add, +, ...\n    * combiner : en cas de parallelisation\n        Ex: Collection.addAll\n    * finisher : transformation finale\n    * options : parallelisable, ordered|unordered\n    \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Collector\n    * initiliaziation : \n        Ex: collection vide, chaîne vide, somme 0 (Supplier)\n    * accumulator : traitemenent des données 1 par 1\n        Ex: Collection.add, +, ...\n    * combiner : en cas de parallelisation\n        Ex: Collection.addAll\n    * finisher : transformation finale\n    * options : parallelisable, ordered|unordered\n    \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
