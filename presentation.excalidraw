      "type": "text",
      "x": 70.10646794304546,
      "y": 2708.821165855503,
      "width": 550.8997192382812,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
