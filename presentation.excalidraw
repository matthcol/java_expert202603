      "updated": 1763920892017,
      "link": null,
      "locked": false,
      "text": "1 version Java = 1 version RI (Reference Implementation)\nplusieurs fournisseurs:\n    - Oracle Java : JRE + JDK\n    - Distribution Linux : RHEL, debian, ...\n    - IBM\n    - Amazon (AWS) : Corretto (cloud, docker, k8s)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 version Java = 1 version RI (Reference Implementation)\nplusieurs fournisseurs:\n    - Oracle Java : JRE + JDK\n    - Distribution Linux : RHEL, debian, ...\n    - IBM\n    - Amazon (AWS) : Corretto (cloud, docker, k8s)",
      "autoResize": true,
